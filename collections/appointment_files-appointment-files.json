{
  "id": "appointment_files",
  "description": "View of files uploaded during a self-assessment",
  "name": "appointment_files",
  "fields": [
    {
      "name": "_id",
      "type": "ObjectId",
      "required": true,
      "nullable": false,
      "description": "_id"
    },
    {
      "name": "creatorId",
      "type": "string",
      "required": true,
      "nullable": false,
      "description": "creatorId"
    },
    {
      "name": "createdAt",
      "type": "Date",
      "required": true,
      "nullable": false,
      "description": "createdAt"
    },
    {
      "name": "updaterId",
      "type": "string",
      "required": true,
      "nullable": false,
      "description": "updaterId"
    },
    {
      "name": "updatedAt",
      "type": "Date",
      "required": true,
      "nullable": false,
      "description": "updatedAt"
    },
    {
      "name": "__STATE__",
      "type": "string",
      "required": true,
      "nullable": false,
      "description": "__STATE__"
    },
    {
      "name": "customerId",
      "type": "string",
      "required": false,
      "nullable": false
    },
    {
      "name": "problem",
      "type": "string",
      "required": false,
      "nullable": false
    },
    {
      "name": "doctor",
      "type": "RawObject",
      "required": false,
      "nullable": false,
      "schema": {
        "properties": {
          "_id": {
            "type": "string",
            "pattern": "^[0-9a-fA-F]{24}$"
          },
          "authUserId": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "profileImageUrl": {
            "type": "string"
          }
        },
        "required": [
          "_id",
          "firstName",
          "lastName"
        ],
        "additionalProperties": true
      }
    },
    {
      "name": "familyMemberId",
      "type": "ObjectId",
      "required": false,
      "nullable": true
    },
    {
      "name": "uploadDate",
      "type": "Date",
      "required": false,
      "nullable": false
    },
    {
      "name": "files",
      "type": "Array",
      "required": true,
      "nullable": false,
      "items": {
        "type": "RawObject",
        "schema": {
          "properties": {
            "storage": {
              "type": "string"
            },
            "name": {
              "type": "string"
            },
            "url": {
              "type": "string"
            },
            "size": {
              "type": "integer"
            },
            "type": {
              "type": "string"
            },
            "originalName": {
              "type": "string"
            },
            "hash": {
              "type": "string"
            }
          },
          "required": [
            "storage",
            "name",
            "url",
            "size",
            "type",
            "originalName",
            "hash"
          ]
        }
      }
    },
    {
      "name": "isEmergency",
      "type": "boolean",
      "required": false,
      "nullable": false
    },
    {
      "name": "kind",
      "type": "string",
      "required": true,
      "nullable": false
    },
    {
      "name": "_doctorId",
      "type": "ObjectId",
      "required": true,
      "nullable": false,
      "description": "This field has been added only to work around the problem that it is not possible to filter on a field of type objectId within an object."
    }
  ],
  "endpointBasePath": "/appointment-files",
  "defaultState": "PUBLIC",
  "type": "view",
  "source": "appointments",
  "pipeline": [
    {
      "$lookup": {
        "from": "self_assessments",
        "localField": "formDataId",
        "foreignField": "_id",
        "as": "selfAssessment"
      }
    },
    {
      "$unwind": "$selfAssessment"
    },
    {
      "$match": {
        "selfAssessment.data.containerLocation.file": {
          "$exists": true,
          "$ne": []
        }
      }
    },
    {
      "$lookup": {
        "from": "users",
        "localField": "doctorId",
        "foreignField": "authUserId",
        "as": "doctor"
      }
    },
    {
      "$unwind": "$doctor"
    },
    {
      "$project": {
        "_id": "$formDataId",
        "__STATE__": "$selfAssessment.__STATE__",
        "_doctorId": "$doctor._id",
        "customerId": "$customerId",
        "files": {
          "$map": {
            "input": "$selfAssessment.data.containerLocation.file",
            "as": "file",
            "in": "$$file"
          }
        },
        "doctor": {
          "_id": "$doctor._id",
          "authUserId": "$doctor.authUserId",
          "firstName": "$doctor.firstName",
          "lastName": "$doctor.lastName",
          "profileImageUrl": {
            "$cond": [
              {
                "$eq": [
                  "$doctor.profileImage",
                  null
                ]
              },
              null,
              "$doctor.profileImage.location"
            ]
          }
        },
        "problem": 1,
        "isEmergency": 1,
        "uploadDate": "$createdAt",
        "familyMemberId": 1,
        "kind": {
          "$cond": [
            {
              "$eq": [
                "$isEmergency",
                true
              ]
            },
            "Teleconsulto di emergenza",
            "Teleconsulto privato"
          ]
        }
      }
    }
  ]
}